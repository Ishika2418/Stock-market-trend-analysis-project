    <worksheet name='Portfolio efficiency'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Portfolio Efficiency(Sharpe)</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='company_info+' name='federated.15ttxwt0h66g091b67vjd0ipov3x' />
          </datasources>
          <datasource-dependencies datasource='federated.15ttxwt0h66g091b67vjd0ipov3x'>
            <column caption='Daily Return%' datatype='real' default-format='p0.00%' name='[Calculation_1859600830500864]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Close])-LOOKUP(SUM([Close]),-1))/LOOKUP(SUM([Close]),-1)'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Portfolio Volatility (Risk)' datatype='real' name='[Calculation_1859600831074305]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='WINDOW_STDEV([Calculation_1859600830500864]) * SQRT(252)'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Sharpe Ratio' datatype='real' name='[Calculation_1859600831459330]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(WINDOW_AVG([Calculation_1859600830500864]) * 252 - 0.05) / [Calculation_1859600831074305]'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column datatype='real' name='[Close]' role='measure' type='quantitative' />
