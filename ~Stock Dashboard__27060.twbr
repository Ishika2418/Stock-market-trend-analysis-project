      <aliases enabled='yes' />
      <column caption='200 Day SMA' datatype='real' name='[200_Day_SMA]' role='dimension' type='quantitative' />
      <column caption='50 Day SMA' datatype='real' name='[50_Day_SMA]' role='dimension' type='quantitative' />
      <column caption='Trend Colorizer' datatype='string' name='[Calculation_0653984221712384]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Close] &gt;= [Open] THEN &quot;Positive&quot; ELSE &quot;Negative&quot; END' />
      </column>
      <column caption='Latest Date' datatype='date' name='[Calculation_0653984221876225]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{FIXED : MAX([Date])}' />
      </column>
      <column caption='Latest Closing Price' datatype='real' name='[Calculation_0653984221974530]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Date] = [Calculation_0653984221876225] THEN [Close] END' />
      </column>
      <column caption='Daily Return%' datatype='real' default-format='p0.00%' name='[Calculation_1859600830500864]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Close])-LOOKUP(SUM([Close]),-1))/LOOKUP(SUM([Close]),-1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Portfolio Volatility (Risk)' datatype='real' name='[Calculation_1859600831074305]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_STDEV([Calculation_1859600830500864]) * SQRT(252)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Sharpe Ratio' datatype='real' name='[Calculation_1859600831459330]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(WINDOW_AVG([Calculation_1859600830500864]) * 252 - 0.05) / [Calculation_1859600831074305]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Simple Return Test' datatype='real' name='[Calculation_1859600837771271]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Close]) - LOOKUP(SUM([Close]), -1))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Latest Date Filter' datatype='boolean' name='[Calculation_1859600846159880]' role='measure' type='nominal'>
        <calculation class='tableau' formula='LAST() = 0'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column datatype='real' name='[Close]' role='measure' type='quantitative' />
